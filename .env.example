# =============================================================================
# Traderie — D2R Market Helper Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values for your local setup.
#   cp .env.example .env
# =============================================================================

# --- Repository Path ---
# Root directory of the traderie repo. Used by launchd wrapper scripts and
# browser capture utilities. Defaults to the checkout location.
# TRADERIE_REPO_DIR=/Users/buddy/projects/traderie

# --- Python ---
# Path to the Python interpreter (typically a venv). The snapshot and
# regeneration scripts reference .venv/bin/python by default.
# PYTHON_BIN=${TRADERIE_REPO_DIR}/.venv/bin/python

# --- Launchd Logs ---
# Directory for launchd stdout/stderr logs. Default: logs/launchd/
# LAUNCHD_LOG_DIR=${TRADERIE_REPO_DIR}/logs/launchd

# --- Reddit Research (optional) ---
# Required only for the tools/subreddit_research/ module.
# REDDIT_CLIENT_ID=your_client_id
# REDDIT_CLIENT_SECRET=your_client_secret
# REDDIT_USER_AGENT="traderie-research/1.0 by your_username"

# --- Storage Adapter (TRD-007) ---
# PostgreSQL adapter is DISABLED by default. Set to "true" to enable.
# TRADERIE_PG_ADAPTER_ENABLED=false
# PostgreSQL connection URL (used when adapter is enabled).
# TRADERIE_PG_URL=postgresql://traderie_writer:password@127.0.0.1:5432/traderie

# --- Schema / Migration Version Reporting ---
# Reported in health exports and parity reports. No live DB needed.
# TRADERIE_SCHEMA_VERSION=9
# TRADERIE_MIGRATION_VERSION=20260705_009_create_health_schema
