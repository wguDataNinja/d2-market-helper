# =============================================================================
# Traderie — Environment Variables (VPS)
# Copy to /home/scraper/config/traderie.env and fill secrets.
# NEVER commit this file to Git.
# =============================================================================

# --- PostgreSQL (optional, default disabled) ---
TRADERIE_PG_ADAPTER_ENABLED=false
TRADERIE_PG_URL=postgresql://traderie_writer:{{PASSWORD}}@127.0.0.1:5432/traderie
TRADERIE_PG_DATABASE=traderie
TRADERIE_PG_WRITER_USER=traderie_writer
TRADERIE_PG_READER_USER=traderie_reader
TRADERIE_PG_MONITOR_USER=traderie_monitor
TRADERIE_PG_MIGRATOR_USER=traderie_migrator
TRADERIE_PG_BACKUP_USER=traderie_backup
TRADERIE_PG_HEALTH_WRITER_USER=traderie_owner
# Optional: use a dedicated DSN for health writes when peer auth is unavailable.
# TRADERIE_PG_HEALTH_WRITER_URL=postgresql://traderie_owner:{{PASSWORD}}@127.0.0.1:5432/traderie

# --- Schema / Migration Version ---
TRADERIE_SCHEMA_VERSION=9
TRADERIE_MIGRATION_VERSION=20260705_009_create_health_schema

# --- Data Directories ---
TRADERIE_DATA_ROOT=/home/scraper/data/traderie
TRADERIE_RAW_ROOT=/home/scraper/data/traderie/raw
TRADERIE_EXPORT_ROOT=/home/scraper/data/traderie/exports
TRADERIE_BACKUP_ROOT=/home/scraper/backups/postgres/traderie

# --- Health Export ---
TRADERIE_HEALTH_OUTPUT=/home/scraper/data/traderie/health/traderie.health.json

# --- Cloudscraper / Browser ---
# Cloudscraper must be running before ingest can succeed.
# Set to the HTTP proxy or socket path used by cloudscraper.
# TRADERIE_SCRAPER_PROXY=http://127.0.0.1:XXXX

# --- Runtime ---
# Python virtual environment
TRADERIE_VENV=/home/scraper/apps/traderie/.venv

# Lock directory (auto-created by systemd ExecStartPre)
TRADERIE_LOCK_DIR=/home/scraper/data/traderie/.locks
